FROM node:20-alpine

RUN apk add --no-cache libc6-compat
WORKDIR /app

# Install ALL deps including devDeps (tsx needed to run TypeScript with path aliases)
COPY package.json ./
RUN npm install --legacy-peer-deps

# Copy source files
COPY tsconfig.json ./
COPY src/workers ./src/workers
COPY src/lib ./src/lib
COPY src/db ./src/db

ENV NODE_ENV=production

# Use tsx to run TypeScript directly — handles @/ path aliases via tsconfig
CMD ["npx", "tsx", "src/workers/index.ts"]
